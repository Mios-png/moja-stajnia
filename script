function getKonie() {
    return JSON.parse(localStorage.getItem('konie')) || [];
}

function toggleKonia(id) {
    let konie = getKonie();

    if (konie.includes(id)) {
        konie = konie.filter(k => k !== id);
    } else {
        konie.push(id);
    }

    localStorage.setItem('konie', JSON.stringify(konie));
    alert("Zapisano!");
}

